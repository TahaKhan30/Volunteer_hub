DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/volunteer_management
JWT_SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost:3000

# Production only (Railway) — leave unset locally for plain-http dev cookies
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# Cloudinary (from cloudinary.com dashboard) — required for photo/resume uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
